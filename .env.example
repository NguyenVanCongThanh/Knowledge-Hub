# General Config
PROJECT_NAME="Knowledge Hub SDLC"

# Qdrant Database Configuration
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Neo4j Database Configuration
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=knowledgehubpassword

# AI & Embedding Model
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Storage Directories
METADATA_DIR=/data/metadata
GITHUB_REPOS_DIR=/data/github_repos

# Groq LLM API Configuration (for Knowledge Extraction)
# Nhập 1 key đơn hoặc nhiều keys ngăn cách bởi dấu phẩy (Ví dụ: gsk_key1,gsk_key2) để tự động xoay vòng tránh rate limit.
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_NAME=llama3-70b-8192
LLM_EXTRACTION_CONCURRENCY=3
